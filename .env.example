# GSS MCP Server — Environment Configuration
# Copy to .env and fill in paths. Never commit .env.

# ── Database paths (absolute paths on the host machine) ─────────────────────
GSS_HISTORY_DB=/path/to/gss-monitor/data/gss_history.db
GSS_API_KEYS_DB=/path/to/gss-mcp-server/data/gss_api_keys.db

# ── Exported data directory (optional — defaults to ../site/public/data/ relative to HISTORY_DB)
# GSS_DATA_DIR=/path/to/gss-monitor/site/public/data

# ── Server settings ─────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8765
MCP_SERVER_NAME=gss-mcp
MCP_SERVER_VERSION=0.1.0

# ── Cloudflare Tunnel (set after tunnel is configured) ──────────────────────
# TUNNEL_URL=https://mcp.greyswansignals.com
